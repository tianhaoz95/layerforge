# Copy this file to .env.local and fill in your Stripe TEST keys.
# .env.local is gitignored — never commit real keys.
#
# These values are only used by the Firebase Functions emulator (pnpm dev / dev.sh).
# Production secrets live in Firebase Secret Manager:
#   firebase functions:secrets:set STRIPE_SECRET_KEY --project layerforge-platform
#
# Get the webhook secret by running the Stripe CLI listener:
#   stripe listen --forward-to localhost:5001/demo-layerforge/us-central1/stripeWebhook

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
