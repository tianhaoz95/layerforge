rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Waitlist: public create (preview app has no sign-in),
    // read/update/delete require auth (admin dashboard only).
    match /waitlist/{entry} {
      allow create: if request.resource.data.keys().hasAll(['name', 'email', 'submittedAt'])
                    && request.resource.data.name is string
                    && request.resource.data.email is string
                    && request.resource.data.submittedAt is string;
      allow read, update, delete: if request.auth != null;
    }

    // User profiles: each user reads their own doc only.
    // Writes are performed exclusively by Cloud Functions via the Admin SDK,
    // which bypasses these rules entirely.
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // Stripe customer → Firebase UID reverse map.
    // Only the Admin SDK (Cloud Functions) reads or writes this collection.
    match /stripeCustomers/{customerId} {
      allow read, write: if false;
    }

  }
}
