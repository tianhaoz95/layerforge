rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Anyone can submit to the waitlist (no sign-in on preview page).
    // Read/update/delete require auth so only the admin dashboard can see entries.
    match /waitlist/{entry} {
      allow create: if request.resource.data.keys().hasAll(['name', 'email', 'submittedAt'])
                    && request.resource.data.name is string
                    && request.resource.data.email is string
                    && request.resource.data.submittedAt is string;
      allow read, update, delete: if request.auth != null;
    }

    // Everything else requires authentication.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

  }
}
