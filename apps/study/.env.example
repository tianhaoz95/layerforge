# Sandbox service URL (proxied via Vite in dev; set to Cloud Functions URL in production)
VITE_SANDBOX_URL=/api/sandbox

# Firebase — required for production; emulator mode uses built-in demo values, so these
# are optional during local development (pnpm dev auto-connects to localhost:9099).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
